{
  "version": 2,

  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python@4.7.2",         
      "config": { "runtime": "python3.12", "maxLambdaSize": "15mb" }
    }
  ],

  "buildCommand":
    "pip install -r requirements.txt && python manage.py collectstatic --noinput",

  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1",            
      "headers": { "cache-control": "public,max-age=31536000,immutable" }
    },
    { "src": "/(.*)", "dest": "index.py" }
  ]
}
